/// Auth-basic plugin configuration.
/// Provides HTTP Basic Authentication for formae agent and CLI.
open module authBasic.Config

extends "formae:/Config.pkl"

class AuthorizedUser {
    username: String
    password: String
}

class AgentConfig extends BaseAgentAuthConfig {
    type = "auth-basic"
    authorizedUsers: Listing<AuthorizedUser>
}

class CliConfig extends BaseCliAuthConfig {
    type = "auth-basic"
    username: String
    password: String
}
